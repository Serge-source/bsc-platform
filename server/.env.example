DATABASE_URL="postgresql://user:password@localhost:5432/bsc_platform"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="your-super-secret-jwt-key-change-this"
JWT_REFRESH_SECRET="your-refresh-secret-change-this"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

NODE_ENV="development"
PORT=3001
CLIENT_URL="http://localhost:5173"

# Email
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your@email.com"
SMTP_PASS="your-app-password"
FROM_EMAIL="noreply@bscplatform.com"

# File Storage (Cloudflare R2 / S3)
STORAGE_ENDPOINT="https://your-account.r2.cloudflarestorage.com"
STORAGE_BUCKET="bsc-files"
STORAGE_ACCESS_KEY=""
STORAGE_SECRET_KEY=""
STORAGE_PUBLIC_URL="https://files.yourdomain.com"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Claude AI
ANTHROPIC_API_KEY="sk-ant-..."

# App
APP_NAME="BSC Platform"
APP_URL="https://yourdomain.com"
